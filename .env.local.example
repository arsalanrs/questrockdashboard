# How to set these in Vercel: Project → Settings → Environment Variables (then redeploy).
# Local: copy to .env.local — see docs/environment-variables.md

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Optional: for `npm run supabase:migrate` only (not used by the Next.js app).
# Paste the full "Session pooler" or "Direct" URI from Dashboard → Database → Connection string (do not edit the host).
# The host must look like aws-0-us-east-1.pooler.supabase.com (real region), not aws-0-....pooler.supabase.com (that will ENOTFOUND).
# DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-us-east-1.pooler.supabase.com:6543/postgres
# Or direct host + password (may fail with ENOTFOUND on IPv4-only networks):
# SUPABASE_DB_PASSWORD=

# "Open in Shape" deep links — Shape URL: https://secure.setshape.com/prospects/{leadId}/edit
# This is now hardcoded in lib/shape-link.ts so this env var is OPTIONAL.
# Only set it if using a white-label or custom Shape domain.
# NEXT_PUBLIC_SHAPE_LEAD_BASE_URL=https://secure.setshape.com/prospects

# Email delivery via Resend (https://resend.com) — for daily/weekly/monthly report emails
# RESEND_API_KEY=re_...
# REPORT_RECIPIENTS=ray@questrock.com,nikk@questrock.com,arsalan@questrock.com
# REPORT_FROM=reports@questrock.com

# Shape API sync (server-only; leave unset for CSV-only)
SHAPE_API_BASE_URL=https://secure-api.setshape.com/api
SHAPE_API_KEY=
SHAPE_CRM_ID=
# Map Shape depursLo / lead_owner_id → display name (see lib/shape-api/lo-roster.ts)
# SHAPE_LO_ROSTER_JSON=[{"name":"Tyler Johnson","depursLo":34},{"name":"Gregory Bethea Jr","depursLo":58}]
# Optional: override Shape lead update URL (default https://secure-api.setshape.com/api/update/lead/info)
# SHAPE_UPDATE_LEAD_URL=https://secure-api.setshape.com/api/update/lead/info

# Cron secret for /api/sync/shape and /api/sync/lendingpad (optional; if set, request must include header x-cron-secret)
CRON_SECRET=
# Vercel Cron calls GET on those paths; send the same header as for Shape sync if you protect with CRON_SECRET.

# LendingPad Web API (read-only GET; HTTP Basic — not Bearer)
LENDINGPAD_API_URL=https://testapi.lendingpad.com
LENDINGPAD_USERNAME=
LENDINGPAD_PASSWORD=
LENDINGPAD_CONTACT_ID=
LENDINGPAD_COMPANY_ID=
# Required for GET /integrations/list/loans when not using per-LO credentials (see Supabase lendingpad_user_credentials)
LENDINGPAD_LIST_USER_ID=
# Alternative: JSON array of { "officerName", "listUserId" } — sync pulls each list without Supabase lendingpad_user_credentials rows.
# If unset, code falls back to lib/lendingpad/default-officers.ts (see data/lendingpad-list-users.json).
# LENDINGPAD_OFFICERS_JSON=[{"officerName":"Bastian Johnston","listUserId":"4bf96b45-2692-4b6b-b635-f606b73e92bc"},...]
# Max loans per conditions/documents sync run — nightly default is 1000, 15-min cron uses
# per-call overrides (200 conditions, 100 documents). Set this to raise the nightly cap further.
# LENDINGPAD_SYNC_MAX_LOANS=1000
# LP loan detail fetch — enabled by default (set to 0 to disable rate/DTI/first-payment enrichment)
# LENDINGPAD_FETCH_LOAN_DETAIL=1

# GoHighLevel integration (future — website traffic via Geoey's setup)
# GHL_API_KEY=
# GHL_LOCATION_ID=
# GHL_WEBHOOK_SECRET=

# OpenAI for AI Guideline Advisor
OPENAI_API_KEY=
